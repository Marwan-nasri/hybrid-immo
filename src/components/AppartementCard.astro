---
import type { Appartement } from '../lib/database.types';

interface Props {
  appartement: Appartement;
}

const { appartement: a } = Astro.props;

const estLoue = a.statut === 'loue';
const photo = a.photos.at(0) ?? null;

const prix = a.prix_mensuel.toLocaleString('fr-FR');

// Libellé + style du badge de statut.
const badge = {
  disponible: null,
  bientot: { texte: 'Bientôt', classe: 'bg-amber-100 text-amber-800' },
  loue: { texte: 'Loué', classe: 'bg-gray-200 text-gray-600' },
}[a.statut];

// Petites infos secondaires, on n'affiche que celles renseignées.
const meta = [
  a.surface != null ? `${a.surface} m²` : null,
  a.nb_pieces != null ? `${a.nb_pieces} pièce${a.nb_pieces > 1 ? 's' : ''}` : null,
  a.meuble ? 'Meublé' : null,
].filter(Boolean);
---

<article
  class:list={[
    'group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5 transition-shadow',
    estLoue ? 'opacity-70' : 'hover:shadow-md',
  ]}
>
  <a href={`/appartements/${a.id}`} class="block">
    <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
      {
        photo ? (
          <img
            src={photo}
            alt={a.titre}
            loading="lazy"
            class:list={[
              'h-full w-full object-cover transition-transform duration-300',
              estLoue ? 'grayscale' : 'group-hover:scale-105',
            ]}
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-sm text-gray-400">
            Pas de photo
          </div>
        )
      }
      {
        badge && (
          <span
            class:list={[
              'absolute left-3 top-3 rounded-full px-2.5 py-1 text-xs font-semibold',
              badge.classe,
            ]}
          >
            {badge.texte}
          </span>
        )
      }
    </div>

    <div class="p-5">
      <div class="flex items-start justify-between gap-3">
        <h3 class="font-semibold leading-tight">{a.titre}</h3>
        <p class="shrink-0 font-bold text-accent">
          {prix}&nbsp;€<span class="text-xs font-normal text-[#6B7280]">/mois</span>
        </p>
      </div>

      <p class="mt-1 text-sm text-[#6B7280]">
        {a.ville}{a.quartier ? ` · ${a.quartier}` : ''}
      </p>

      {
        meta.length > 0 && (
          <p class="mt-3 text-sm text-[#6B7280]">{meta.join(' · ')}</p>
        )
      }
    </div>
  </a>
</article>
