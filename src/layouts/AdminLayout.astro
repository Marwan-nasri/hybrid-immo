---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const user = Astro.locals.user;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} — Admin hybrid'immo</title>
  </head>
  <body class="min-h-screen bg-canvas font-sans text-[#1A1A1A] antialiased">
    <header class="border-b border-black/5 bg-white">
      <!-- flex-wrap : sur mobile la nav passe en pleine largeur sous le logo
           (order-last + w-full), sur sm+ elle revient inline à côté du logo. -->
      <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-6 gap-y-3 px-4 py-4 sm:px-6">
        <a href="/admin" class="text-lg font-bold tracking-tight">
          hybrid<span class="text-accent">'immo</span>
          <span class="ml-1 text-xs font-medium text-[#6B7280]">admin</span>
        </a>
        <nav class="order-last flex w-full gap-5 text-sm font-medium text-[#6B7280] sm:order-none sm:w-auto">
          <a href="/admin" class="hover:text-[#1A1A1A]">Dashboard</a>
          <a href="/admin/demandes" class="hover:text-[#1A1A1A]">Demandes</a>
        </nav>
        <div class="ml-auto flex items-center gap-4 text-sm">
          {user && <span class="hidden text-[#6B7280] md:inline">{user.email}</span>}
          <form method="post" action="/admin/logout">
            <button class="rounded-full px-3 py-1.5 font-medium text-[#6B7280] ring-1 ring-black/10 hover:bg-black/5">
              Déconnexion
            </button>
          </form>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-8">
      <slot />
    </main>
  </body>
</html>
