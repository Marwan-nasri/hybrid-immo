---
import Layout from '../layouts/Layout.astro';

const tagline = "L'immobilier hybride : l'expertise humaine augmentée par le digital.";
---

<Layout title="hybrid'immo" description={tagline}>
  <section class="mx-auto flex max-w-3xl flex-col items-center px-6 py-24 text-center sm:py-32">
    <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
      hybrid<span class="text-accent">'immo</span>
    </h1>
    <p class="mt-6 max-w-xl text-lg text-[#6B7280]">
      {tagline}
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/appartements"
        class="rounded-full bg-accent px-6 py-3 font-semibold text-white transition-opacity hover:opacity-90"
      >
        Voir les appartements
      </a>
      <a
        href="/demande"
        class="rounded-full px-6 py-3 font-semibold text-[#1A1A1A] ring-1 ring-black/10 transition-colors hover:bg-black/5"
      >
        Faire une demande
      </a>
    </div>
  </section>
</Layout>
