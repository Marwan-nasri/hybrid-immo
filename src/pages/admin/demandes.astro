---
import AdminLayout from '../../layouts/AdminLayout.astro';
import type { StatutDemande } from '../../lib/database.types';

const supabase = Astro.locals.supabase;

const STATUTS: StatutDemande[] = ['nouvelle', 'contactee', 'en_cours', 'acceptee', 'refusee'];
const STATUT_LABEL: Record<StatutDemande, string> = {
  nouvelle: 'Nouvelle',
  contactee: 'Contactée',
  en_cours: 'En cours',
  acceptee: 'Acceptée',
  refusee: 'Refusée',
};
const STATUT_BADGE: Record<StatutDemande, string> = {
  nouvelle: 'bg-accent text-white',
  contactee: 'bg-amber-100 text-amber-800',
  en_cours: 'bg-indigo-100 text-indigo-800',
  acceptee: 'bg-green-100 text-green-800',
  refusee: 'bg-gray-200 text-gray-600',
};

// --- Traitement des actions (POST) ---
let proposerLoue: string | null = null; // id appartement à proposer en "loué"

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');

  if (action === 'statut') {
    const demandeId = (form.get('demande_id') ?? '').toString();
    const statut = (form.get('statut') ?? '').toString() as StatutDemande;
    const appartementId = (form.get('appartement_id') ?? '').toString();
    if (STATUTS.includes(statut) && demandeId) {
      await supabase.from('demandes').update({ statut }).eq('id', demandeId);
      // Si acceptée et liée à un appartement → on proposera de le passer en "loué".
      if (statut === 'acceptee' && appartementId) {
        return Astro.redirect(`/admin/demandes?proposer=${appartementId}`);
      }
    }
  } else if (action === 'marquer_loue') {
    const appartementId = (form.get('appartement_id') ?? '').toString();
    if (appartementId) {
      await supabase.from('appartements').update({ statut: 'loue' }).eq('id', appartementId);
      return Astro.redirect('/admin/demandes?loue=1');
    }
  }
}

const params = Astro.url.searchParams;
proposerLoue = params.get('proposer');
const vientDePasserLoue = params.get('loue') === '1';

// --- Chargement des données ---
const { data: demandes } = await supabase
  .from('demandes')
  .select('*')
  .order('created_at', { ascending: false });

const { data: appartements } = await supabase.from('appartements').select('id, titre, statut');
const apparts = new Map((appartements ?? []).map((a) => [a.id, a]));

// Groupement des demandes par appartement (clé '' = demandes générales).
const groupes = new Map<string, typeof demandes>();
for (const d of demandes ?? []) {
  const cle = d.appartement_id ?? '';
  if (!groupes.has(cle)) groupes.set(cle, []);
  groupes.get(cle)!.push(d);
}
// Ordre d'affichage : appartements d'abord, "générales" à la fin.
const cles = [...groupes.keys()].sort((a, b) => (a === '' ? 1 : b === '' ? -1 : 0));

const apartAProposer = proposerLoue ? apparts.get(proposerLoue) : null;

const dateFr = (d: string) =>
  new Date(d).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
---

<AdminLayout title="Demandes">
  <h1 class="text-2xl font-bold tracking-tight">Demandes</h1>

  {vientDePasserLoue && (
    <p class="mt-4 rounded-lg bg-green-50 px-4 py-3 text-sm text-green-800">
      Appartement passé en « Loué ».
    </p>
  )}

  {apartAProposer && apartAProposer.statut !== 'loue' && (
    <div class="mt-4 flex flex-wrap items-center justify-between gap-3 rounded-lg bg-accent/10 px-4 py-3 text-sm">
      <span>
        Demande acceptée. Passer <strong>{apartAProposer.titre}</strong> en « Loué » ?
      </span>
      <div class="flex items-center gap-3">
        <form method="post">
          <input type="hidden" name="_action" value="marquer_loue" />
          <input type="hidden" name="appartement_id" value={apartAProposer.id} />
          <button class="rounded-full bg-accent px-4 py-1.5 font-semibold text-white hover:opacity-90">
            Oui, marquer loué
          </button>
        </form>
        <a href="/admin/demandes" class="font-medium text-[#6B7280] hover:text-[#1A1A1A]">Non</a>
      </div>
    </div>
  )}

  {(demandes ?? []).length === 0 && (
    <p class="mt-6 rounded-2xl bg-white p-8 text-center text-[#6B7280] ring-1 ring-black/5">
      Aucune demande pour le moment.
    </p>
  )}

  <div class="mt-6 space-y-8">
    {
      cles.map((cle) => {
        const liste = groupes.get(cle)!;
        const appart = cle ? apparts.get(cle) : null;
        return (
          <section>
            <div class="mb-3 flex items-center gap-2">
              <h2 class="text-lg font-semibold">
                {appart ? appart.titre : 'Demandes générales'}
              </h2>
              <span class="text-sm text-[#6B7280]">({liste.length})</span>
              {appart && (
                <a href={`/admin/appartements/${appart.id}`} class="text-sm text-accent hover:underline">
                  éditer
                </a>
              )}
            </div>

            <div class="space-y-3">
              {liste.map((d) => (
                <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-black/5">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <p class="font-semibold">{d.nom}</p>
                      <p class="text-sm text-[#6B7280]">
                        <a href={`mailto:${d.email}`} class="hover:underline">{d.email}</a>
                        {' · '}
                        <a href={`tel:${d.telephone}`} class="hover:underline">{d.telephone}</a>
                      </p>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class:list={['rounded-full px-2.5 py-1 text-xs font-semibold', STATUT_BADGE[d.statut]]}>
                        {STATUT_LABEL[d.statut]}
                      </span>
                      <span class="text-xs text-[#6B7280]">{dateFr(d.created_at)}</span>
                    </div>
                  </div>

                  {(d.budget || d.ville || d.date_entree || d.nb_personnes || d.message) && (
                    <div class="mt-3 flex flex-wrap gap-x-6 gap-y-1 text-sm text-[#374151]">
                      {d.ville && <span>Ville : {d.ville}</span>}
                      {d.budget != null && <span>Budget : {d.budget} €</span>}
                      {d.date_entree && <span>Entrée : {dateFr(d.date_entree)}</span>}
                      {d.nb_personnes != null && <span>Personnes : {d.nb_personnes}</span>}
                    </div>
                  )}
                  {d.message && <p class="mt-2 text-sm text-[#374151] whitespace-pre-line">{d.message}</p>}

                  <form method="post" class="mt-4 flex items-center gap-2">
                    <input type="hidden" name="_action" value="statut" />
                    <input type="hidden" name="demande_id" value={d.id} />
                    <input type="hidden" name="appartement_id" value={d.appartement_id ?? ''} />
                    <label class="text-xs text-[#6B7280]">Statut :</label>
                    <select
                      name="statut"
                      class="statut-select rounded-lg border border-black/10 bg-white px-2 py-1 text-sm"
                    >
                      {STATUTS.map((s) => (
                        <option value={s} selected={s === d.statut}>{STATUT_LABEL[s]}</option>
                      ))}
                    </select>
                    <button class="rounded-full bg-[#1A1A1A] px-3 py-1 text-xs font-semibold text-white hover:opacity-90">
                      Mettre à jour
                    </button>
                  </form>
                </div>
              ))}
            </div>
          </section>
        );
      })
    }
  </div>
</AdminLayout>

<script>
  // Changement de statut « en un clic » : soumet le formulaire dès qu'on change le menu.
  document.querySelectorAll<HTMLSelectElement>('.statut-select').forEach((sel) => {
    sel.addEventListener('change', () => sel.form?.requestSubmit());
  });
</script>
